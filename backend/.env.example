LLM_MODEL=claude-sonnet-4-6
KNOWLEDGE_DIR=knowledge

# Required. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=change-me

# Optional
JWT_TTL_SECONDS=86400
ALLOWED_ORIGINS=["http://localhost:5173"]
# Flip on in production (HTTPS) so the session cookie is only sent over TLS.
COOKIE_SECURE=false
LOG_LEVEL=INFO
# Set false in production to hide /docs, /redoc, /openapi.json entirely.
EXPOSE_API_DOCS=true
# Reject ingest if compile output covers < this ratio of the raw document (fights over-summarization).
COMPILE_MIN_COVERAGE=0.2
